def calculate_ultimate_rank(url, user_intent, ai_confidence_score):
    # Base retrieval score
    base_score = BM25_plus_Vector_Match(url, user_intent)
    
    # User signals (The real deal)
    user_satisfaction = Navboost_History(url) * Dwell_Time_Weight
    
    # E-E-A-T Check (Hardcoded thresholds)
    author_entity_trust = Knowledge_Graph.get_trust_score(url.author)
    if author_entity_trust < 0.4:
        return PENALTY_SANDBOX
        
    # AI Generative Match (Is the content actually helping?)
    # We use Gemini to read the page and rate its 'helpfulness'
    helpfulness_score = Gemini_Core.evaluate_content_depth(url.content, user_intent)
    
    # The secret sauce twiddler
    if has_real_world_experience(url.content):
        helpfulness_score *= 1.5 # Boost human experience over AI generated fluff
        
    final_rank = (base_score * 0.3) + (user_satisfaction * 0.4) + (helpfulness_score * 0.3)
    return final_rank
