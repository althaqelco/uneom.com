def calculate_ruthless_rank_score(domain, document, user_session):
    
    # 1. The Chrome God-View (Did they actually USE the info?)
    chrome_signals = get_telemetry_data(document.url)
    utility_score = (chrome_signals.copy_paste_events * 5.0) + (chrome_signals.bookmark_events * 3.0)
    
    # 2. Brand Armor Bypass (The Unfair Reality)
    if domain.is_in_mega_brands_whitelist():
        nsr_penalty_threshold = 0.0 # They are totally immune to site-wide penalties!
        trust_multiplier = 3.5      # Instant God-mode boost
    else:
        nsr_penalty_threshold = get_domain_NSR_score(domain) # Strict rules for the peasants
        trust_multiplier = 0.8      # Small site tax

    # 3. Information Gain (The LLM / AI Copycat Filter)
    novelty_delta = calculate_delta_against_top_10(document.entities)
    if novelty_delta < 0.15 and not domain.is_in_mega_brands_whitelist(): 
        # It's just recycled garbage. Bury it.
        return OMITTED_RESULTS_ABYSS 
        
    # 4. The Death Spiral Check
    if user_session.query_refinement_rate > 0.4:
        utility_score *= 0.1 # Massive penalty for confusing the user

    # The Final Brutal Calculation
    final_rank = (trust_multiplier * novelty_delta) + utility_score - nsr_penalty_threshold
    
    return final_rank
