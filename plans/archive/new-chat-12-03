import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

export function middleware(request: NextRequest) {
  const url = request.nextUrl.clone();
  
  // 1. 🚨 [استشعار الحمض النووي الجغرافي للزائر من حافة الشبكة] 🚨
  const cityHeader = request.headers.get('x-vercel-ip-city') || request.headers.get('cf-ipcity') || '';
  
  // قاموس فك التشفير وتوحيد أسماء المدن
  const citySlugMap: Record<string, string> = {
    'riyadh': 'riyadh', 'jeddah': 'jeddah', 'dammam': 'dammam', 'makkah': 'makkah',
    // أضف بقية مدن المملكة هنا
  };

  const userCitySlug = citySlugMap[cityHeader.toLowerCase()];

  // 2. 🎯 [القفزة الكمّية - The Quantum Leap]
  // إذا طلب الزائر الصفحة العامة (مثلاً /water-leak-detection) وهو في الرياض
  // نطعمه صفحة الرياض سراً بـ 0ms تأخير!
  const isGenericService = /^\/[a-zA-Z0-9-]+$/.test(url.pathname); 
  
  if (isGenericService && userCitySlug) {
    const serviceSlug = url.pathname.replace('/', '');
    
    // استثناء المسارات الأساسية للـ API والـ Admin
    if (!['api', 'admin', 'blog', 'company', 'regions'].includes(serviceSlug)) {
      
      // الكود المرعب: تغيير المحتوى المعروض للعميل بدون تغيير الرابط في المتصفح!
      url.pathname = `/${userCitySlug}/${serviceSlug}`;
      return NextResponse.rewrite(url); 
    }
  }

  // .. (كود الـ Redirects القديم الخاص بك يبقى هنا) ..
  return NextResponse.next();
}
