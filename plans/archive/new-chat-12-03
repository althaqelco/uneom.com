'use server';

import { headers } from 'next/headers';

// 🚨 [النبض الخفي] - هذه الدالة تُستدعى من الخلفية ولا يمكن لأي AdBlocker إيقافها
export async function trackConversionS2S(eventName: string, payload: any) {
  const headersList = await headers();
  
  // التقاط البصمة الحقيقية للمستخدم لتمريرها لجوجل كدليل قاطع على أنه إنسان
  const ip = headersList.get('x-forwarded-for') || '127.0.0.1';
  const userAgent = headersList.get('user-agent') || 'unknown';

  // مفاتيح GA4 (يجب إضافتها في ملف .env)
  const GA_MEASUREMENT_ID = process.env.GA_MEASUREMENT_ID; // G-XXXXXXXXXX
  const GA_API_SECRET = process.env.GA_API_SECRET; // من إعدادات Data Streams

  if (!GA_MEASUREMENT_ID || !GA_API_SECRET) return { success: false };

  try {
    // 💥 الضربة الشبحية المباشرة لقلب قاعدة بيانات جوجل Analytics
    await fetch(`https://www.google-analytics.com/mp/collect?measurement_id=${GA_MEASUREMENT_ID}&api_secret=${GA_API_SECRET}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        client_id: payload.clientId || crypto.randomUUID(), 
        events: [{
          name: eventName, // مثال: 'whatsapp_lead_generated'
          params: {
            ...payload,
            engagement_time_msec: "1000", // إشارة لجوجل بوجود تفاعل عميق وحقيقي
            server_ip: ip, // 🛡️ جوجل يثق ببيانات الخادم جداً
            user_agent: userAgent,
            traffic_type: 'server_side_secured'
          }
        }]
      })
    });
    
    return { success: true };
  } catch (error) {
    return { success: false }; // صمت تكتيكي: لا نكسر تجربة المستخدم أبدًا
  }
}
