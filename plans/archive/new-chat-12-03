const CITY_TIERS: Record<number, string[]> = {
  0: ['riyadh', 'jeddah', 'dammam'], // مدن العاصمة تفتح فوراً (اليوم 0)
  7: ['makkah', 'madinah', 'khobar'],  // تفتح بعد أسبوع
