'use server';
import { google } from 'googleapis'; // npm install googleapis

// 🚨 [الحقن الوريدي المباشر في قاعدة بيانات جوجل] 🚨
export async function pushToGoogleCore(urlToPush: string, type: 'URL_UPDATED' | 'URL_DELETED' = 'URL_UPDATED') {
  try {
    // تتطلب هذه الخطوة إنشاء Service Account في Google Cloud وربطه بـ Search Console (تُحفظ المفاتيح في .env)
    const jwtClient = new google.auth.JWT(
      process.env.GOOGLE_CLIENT_EMAIL,
      null,
      process.env.GOOGLE_PRIVATE_KEY?.replace(/\\n/g, '\n'),
      ['https://www.googleapis.com/auth/indexing'],
      null
    );

    await jwtClient.authorize();

    // إطلاق النبضة العصبية (Ping) مباشرة لنواة جوجل
    const response = await fetch('https://indexing.googleapis.com/v3/urlNotifications:publish', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${jwtClient.credentials.access_token}`,
      },
      body: JSON.stringify({
        url: urlToPush,
        type: type, // يخبر جوجل: "كيان جديد وُلد" أو "كيان تم إعدامه"
      }),
    });

    console.log(`[NEURAL SYNC] Google core updated for: ${urlToPush}`);
    return true;
  } catch (error) {
    console.error('[NEURAL SYNC FAILED]', error);
    return false;
  }
}
