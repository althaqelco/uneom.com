export function VectorResonanceSchema({ serviceAr, cityAr, serviceSlug }: any) {
  // 1. 🌌 قاموس الشفرات الكونية (Wikidata Entities)
  // نحن نربط خدماتنا بمفاهيم عالمية يثق بها جوجل 100%
  const WIKIDATA_NODES: Record<string, string> = {
    'water-leak-detection': 'https://www.wikidata.org/wiki/Q1135898', // المعرف العالمي لكشف التسربات
    'pest-control': 'https://www.wikidata.org/wiki/Q1333036',         // المعرف العالمي لمكافحة الآفات
    'furniture-moving': 'https://www.wikidata.org/wiki/Q1807490'      // المعرف العالمي للوجستيات
  };

  const entityUrl = WIKIDATA_NODES[serviceSlug];
  if (!entityUrl) return null;

  // 2. 🚨 [الحقن الرياضي - Mathematical Injection] 🚨
  const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": `${serviceAr} في ${cityAr}`,
    "provider": { "@id": "https://prokr.co/#organization" },
    
    // السحر الأسود هنا: نُعرّف الخدمة لجوجل بأنها "النسخة المحلية" من المفهوم العلمي العالمي!
    "sameAs": [ entityUrl ],
    
    // إخبار جوجل أن هذه الصفحة "تحل مشكلة" مُعرفة علمياً
    "isRelatedTo": {
      "@type": "DefinedTerm",
      "name": `علم ومعايير ${serviceAr}`,
      "inDefinedTermSet": "https://www.wikidata.org"
    }
  };

  return <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }} />;
}
