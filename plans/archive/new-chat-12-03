export function PhantomPhone({ encodedPhone }: { encodedPhone: string }) {
  // encodedPhone هو الرقم مشفر بـ Base64 (مثلاً من السيرفر: btoa('0501234567'))
  const [phone, setPhone] = useState<string>('اضغط لإظهار الرقم المعتمد');
