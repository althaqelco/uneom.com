import { trackConversionS2S } from '@/actions/telemetry'; // من بروتوكول 3

export function LiveVerificationTrap({ crnNumber, companyName }: { crnNumber: string, companyName: string }) {
  const [status, setStatus] = useState<'idle' | 'verifying' | 'verified'>('idle');

  const startVerification = () => {
    setStatus('verifying');
    
    // 🚨 [مصيدة الوقت - The Navboost Hack] 🚨
    // نجبر المستخدم على الانتظار 4.5 ثانية وهو يراقب الشاشة.
    // هذا يرسل إشارة لمتصفح كروم (CrUX) أن المستخدم "مهتم جداً" ويتفاعل بعمق.
    setTimeout(() => {
      setStatus('verified');
      trackConversionS2S('crn_verified_by_user', { crn: crnNumber });
    }, 4500); 
  };

  if (!crnNumber) return null;

  return (
    <div className="mt-4 p-5 bg-slate-50 border border-slate-200 rounded-2xl max-w-md shadow-sm">
      {status === 'idle' && (
        <button onClick={startVerification} className="w-full bg-slate-900 text-white font-bold py-3 rounded-xl hover:bg-slate-800 transition-all">
          🛡️ التحقق المباشر من السجل التجاري
