import { Advertiser } from '@/types/advertiser';

export function CompanyJsonLd({ advertiser }: { advertiser: Advertiser }) {
  const sameAsLinks = [];
  if (advertiser.social_links?.twitter) sameAsLinks.push(advertiser.social_links.twitter);
  if (advertiser.social_links?.google_business) sameAsLinks.push(advertiser.social_links.google_business);

  // 🚨 [جسر الثقة العكسي - Outbound Trust Signal] 🚨
  // إذا كان السجل التجاري موجوداً وموثقاً، نضيف رابط استعلام وزارة التجارة كـ SameAs!
  // هذا يخبر خوارزمية جوجل: "اذهب وتحقق من هذا الكيان في المصدر الحكومي الموثوق".
  if (advertiser.crn_number && advertiser.is_crn_verified) {
    sameAsLinks.push(`https://mc.gov.sa/ar/eservices/Pages/Commercial-data.aspx?cr=${advertiser.crn_number}`);
  }

  const schema = {
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness", // نوع دقيق يعشقه جوجل في مجالك أكثر من LocalBusiness
    "@id": `https://prokr.co/company/${advertiser.code}#business`,
    "name": advertiser.name,
    "url": `https://prokr.co/company/${advertiser.code}`,
    "telephone": advertiser.phone,
    "image": advertiser.logo || "https://prokr.co/default-logo.png",
    
    // 💥 الضربة القاضية: الحقن الحكومي المباشر 💥
    // Schema.org لا يملك حقل 'crnNumber' صريح، لذلك نستخدم المعرفات الديناميكية (PropertyValue)
    ...(advertiser.crn_number && advertiser.is_crn_verified && { 
      "identifier": {
        "@type": "PropertyValue",
        "name": "السجل التجاري السعودي (CRN)",
        "propertyID": "CRN",
        "value": advertiser.crn_number
      }
    }),

    // ربط الكيان الرقمي
    ...(sameAsLinks.length > 0 && { "sameAs": sameAsLinks }),

    // 🏢 [التبعية السيادية] - إخبار جوجل أن هذه الشركة تابعة لشبكتك أنت!
    "parentOrganization": {
      "@type": "Organization",
      "@id": "https://prokr.co/#organization"
    },

    // ... أبقِ على معلومات التقييمات والعنوان الحالية لديك
  };

  return (
    <script
      type="application/ld+json"
      dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }}
    />
  );
}
