export default async function sitemap({ id }: { id: number }): Promise<MetadataRoute.Sitemap> {
  // 💡 نصيحة معمارية (Cost Engineering):
  // إذا كنت تستخدم firebase-admin على السيرفر، استخدم .select('updated_at', 'created_at')
  // في استعلامك. هذا يقلل حجم البيانات المحملة للذاكرة بنسبة 99% ويحمي الخادم من الانهيار.
