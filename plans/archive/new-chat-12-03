  // ... بقية المدن المائة تفتح بعد 30 يوماً
};

export function middleware(request: NextRequest) {
  const url = request.nextUrl.pathname;
  const daysSinceLaunch = Math.floor((Date.now() - LAUNCH_DATE) / (1000 * 60 * 60 * 24));

  // فحص ما إذا كانت المدينة المطلوبة قد حان وقت فتحها خوارزمياً
  for (const [unlockDay, cities] of Object.entries(CITY_TIERS)) {
